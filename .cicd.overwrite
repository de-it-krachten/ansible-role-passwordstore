---

# Generic
generic:
  role: ansible-role-passwordstore
  role_short: passwordstore
  role_description: |
    Installs passwordstore 
  collections: []

# Supported platforms
platforms:
  sles15:
    supported: true
    ci: false
  sles16:
    supported: true
    ci: false
  opensuse15:
    supported: true
    ci: true
  opensuse16:
    supported: true
    ci: true
  ubuntu2004:
    supported: true
    ci: true

# Molecule
molecule:
  requirements:
    roles_extra:
      - deitkrachten.gpg
  prepare:
    vars:
      activate_epel: true
  converge:
    roles:
      - deitkrachten.gpg
    vars:
      gpg_user_name: root
      gpg_user_realname: root
      gpg_user_comment: "test key"
      gpg_user_email: "root@localhost"
      gpg_user_passphrase: "Abcd1234"
      passwordstore_user_name: root
      passwordstore_group_name: root
      passwordstore_user_email: root@localhost
